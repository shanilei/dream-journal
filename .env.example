# העתק קובץ זה ל-.env ומלא את המפתח האמיתי שלך מ-console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
# Phase 1 auth infrastructure — public, safe to expose to the browser
# (this is what the browser/server Supabase clients in src/lib/supabase
# use; SUPABASE_URL above is unchanged and still used only by the
# admin/service-role client in src/supabase-admin.ts). Same project URL
# as SUPABASE_URL, just under the NEXT_PUBLIC_ name Next.js requires for
# any client-side env var. Get the anon key from Supabase dashboard →
# Project Settings → API → "anon public" key.
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=...
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...
